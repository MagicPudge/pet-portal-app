# =========================
# App Runtime (Shopify)
# =========================
NODE_ENV=production
PORT=3000

# 必填：你的线上域名（必须 https）
SHOPIFY_APP_URL=https://app.yourdomain.com

# 必填：来自 Shopify Partner 后台
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# 必填：要和 shopify.app.toml 里的 scopes 一致
SCOPES=write_app_proxy,write_metaobject_definitions,write_metaobjects,write_products

# 可选：仅在你用自定义 shop 域名时填写
# SHOP_CUSTOM_DOMAIN=shop.yourdomain.com


# =========================
# Supabase (Pet Portal 业务)
# =========================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_BUCKET=pet-photos

# 可选：不填默认 public
SUPABASE_SCHEMA=public

# 仅本地调试可用，生产建议留空
# PET_PORTAL_DEV_CUSTOMER_ID=1234567890


# =========================
# Optional: Email (如果你项目里启用了欢迎邮件)
