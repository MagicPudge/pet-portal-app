// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model WelcomeEmailLog {
  id              String             @id @default(cuid())
  emailNormalized String             @unique
  customerId      String?
  shop            String
  status          WelcomeEmailStatus
  sentAt          DateTime?
  provider        String
  errorMessage    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model PetProfile {
  id           String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  shopDomain   String   @map("shop_domain")
  customerId   String   @map("customer_id")
  email        String?  @db.Text
  firstName    String?  @map("first_name") @db.Text
  lastName     String?  @map("last_name") @db.Text
  petName      String   @map("pet_name") @db.Text
  petType      PetType  @map("pet_type")
  breed        String?  @db.Text
  gender       Gender   @default(unknown)
  birthday     DateTime? @db.Date
  adoptionDate DateTime? @map("adoption_date") @db.Date
  weightKg     Decimal? @map("weight_kg") @db.Decimal(10, 2)
  photoPath    String?  @map("photo_path") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("pet_profiles")
  @@index([shopDomain, customerId], map: "pet_profiles_shop_customer_idx")
  @@unique([shopDomain, customerId, petName], map: "pet_profiles_shop_customer_pet_name_key")
}

enum PetType {
  dog
  cat
  other
}

enum Gender {
  male
  female
  unknown
}

enum WelcomeEmailStatus {
  SENT
  FAILED
}
