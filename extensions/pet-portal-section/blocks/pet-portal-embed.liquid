{% liquid
  assign min_height = block.settings.min_height | default: 960
%}

{{ 'pet-portal-embed.css' | asset_url | stylesheet_tag }}

<div class="pet-portal-embed" style="--pet-portal-min-height: {{ min_height }}px;" {{ block.shopify_attributes }}>
  <iframe
    class="pet-portal-embed__frame"
    src="/apps/pet-portal"
    title="Pet Portal"
    loading="lazy"
    allow="clipboard-write"
  ></iframe>
</div>

{% schema %}
{
  "name": "Pet portal",
  "target": "section",
  "settings": [
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 480,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 960
    }
  ]
}
{% endschema %}
